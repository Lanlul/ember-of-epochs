# LLM Provider
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o-mini
LLM_API_KEY=
LLM_API_BASE=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_REPETITION_PENALTY=1.15
LLM_FREQUENCY_PENALTY=0.5
LLM_PRESENCE_PENALTY=0.0

# Image Generation (BigPickle / Diffusers)
BIGPICKLE_MODEL_PATH=models/sdxl-turbo
BIGPICKLE_DEVICE=cuda
BIGPICKLE_INFERENCE_STEPS=4
BIGPICKLE_CFG_SCALE=0.0

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
